# ================= FLASK-MAIL CONFIGURATION =================
# Required for Forgot Password feature

# Gmail SMTP Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True

# Gmail App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# Sender Email
MAIL_DEFAULT_SENDER=noreply@binocularai.com

# ================= SETUP INSTRUCTIONS =================
# 
# 1. Create a Gmail account or use existing one
# 2. Enable 2-Factor Authentication on your Google Account
# 3. Generate App Password:
#    - Go to https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer"
#    - Copy the 16-character password
# 4. Rename this file to .env (without .example)
# 5. Fill in your credentials
# 6. Install python-dotenv:
#    pip install python-dotenv
# 7. Load env variables in app.py (already done)
#
# ================= ALTERNATIVE EMAIL PROVIDERS =================
#
# SendGrid:
#   MAIL_SERVER=smtp.sendgrid.net
#   MAIL_PORT=587
#   MAIL_USERNAME=apikey
#   MAIL_PASSWORD=SG.xxxxx
#
# Outlook/Office365:
#   MAIL_SERVER=smtp.office365.com
#   MAIL_PORT=587
#   MAIL_USERNAME=your-email@outlook.com
#   MAIL_PASSWORD=your-password
#
# ================= SECURITY NOTES =================
# - NEVER commit .env file to version control
# - Add .env to .gitignore
# - Use strong, unique app passwords
# - For production, use environment variables from hosting platform
